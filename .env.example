# ─────────────────────────────────────────────────────────────
# Scout — AI Company Research Assistant · environment variables
# ─────────────────────────────────────────────────────────────
# ALL of these are OPTIONAL as env vars: the app also accepts keys
# entered in the in-app Settings panel (kept in memory for the session).
# Set them here to bake keys into a deployment so evaluators don't
# have to paste anything.

# Required for AI analysis (mandatory per spec). Free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Recommended. Powers name→official-site resolution, contact & competitor search.
# Free tier (2,500 queries): https://serper.dev
SERPER_API_KEY=

# Optional — Discord bonus. Auto-sends the report + PDF after generation.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
